# =============================================================================
# Tensor Pipeline — Environment Configuration
# =============================================================================
# Copy to .env and customize:  cp .env.example .env

# Model Configuration
MODEL_NAME=resnet50
MODEL_VERSION=1

# Optimization Settings
OPTIMIZE_TRT=false
OPTIMIZE_ONNX=true
TRT_PRECISION=FP16

# Gateway Settings
LOG_LEVEL=INFO
MAX_BATCH_SIZE=8
REQUEST_TIMEOUT=30

# Monitoring (optional)
GRAFANA_PASSWORD=admin

# MLflow (optional)
# MLFLOW_TRACKING_URI=http://mlflow:5000
